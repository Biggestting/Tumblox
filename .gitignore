# Xcode — per-user state (never commit these)
*.xcuserstate
*.xcscmblueprint
xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcworkspace/xcuserdata/
# NOTE: Tumblox.xcodeproj itself IS committed (generated by XcodeGen from project.yml)
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Build artifacts
build/
Products/

# Package resolution
.build/
Packages/
*.resolved

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Provisioning profiles (never commit)
*.mobileprovision
*.provisionprofile

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
